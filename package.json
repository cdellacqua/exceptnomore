{
  "name": "exceptnomore",
  "camelCaseName": "exceptNoMore",
  "version": "1.2.14",
  "description": "Result and Optional types that will make your code exception-proof",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "coverage": "vitest run --coverage",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "vite build --mode lib && vite build --mode umd && node --input-type=module -e \"import {copyFileSync} from 'node:fs'; copyFileSync('dist/index.d.ts', 'dist/index.d.cts');\"",
    "typecheck": "tsc",
    "doc": "rimraf docs && typedoc --gitRevision master --readme none --plugin typedoc-plugin-markdown src/index.ts",
    "publint": "publint",
    "check": "npm run lint && npm run typecheck && npm run test && npm run publint",
    "prepack": "npm run check && npm run build && npm run doc",
    "lint": "eslint --max-warnings 0 .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  "keywords": [
    "result",
    "optional",
    "maybe",
    "monad"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cdellacqua/exceptnomore.git"
  },
  "bugs": {
    "url": "https://github.com/cdellacqua/exceptnomore/issues"
  },
  "homepage": "https://github.com/cdellacqua/exceptnomore",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "author": "Carlo Dell'Acqua",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "publint": "^0.3.18",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.5"
  }
}
